# Supabase – find these in your Supabase project settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=<anon-key>
SUPABASE_SECRET_KEY=<service-role-key>

# JWT signing keys (auth performance) – no env var to set, but affects auth speed.
# Auth uses supabase.auth.getClaims(), which verifies the session JWT locally
# (no call to the Supabase Auth API on every /admin request) ONLY when the project
# has an active asymmetric (ECC/RSA) signing key. Check at:
#   Supabase dashboard → Project Settings → JWT Keys  (/project/_/settings/jwt)
#   - Projects created after 2025-10-01 already use an asymmetric key by default.
#   - Legacy projects show a shared "JWT secret"; create/rotate to an asymmetric
#     signing key there to enable local verification.
# getClaims() works either way — without an asymmetric key it transparently falls
# back to a network round-trip per request, so the code is safe to ship now.

# Postgres – use the Session Pooler connection string (port 6543) from Supabase → Settings → Database
# Required: ?sslmode=require  and  &prepare=false  for Drizzle ORM compatibility
DATABASE_URL=postgres://postgres.<project-ref>:<password>@aws-1-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require&prepare=false

# ============================================================================
# Initial Project Setup & Deployment
# ============================================================================
#
# 1. Apply Database Schema Migrations:
#    npm run db:migrate
#
# 2. Bootstrap the First Admin/Owner:
#    - Create the user account in your Supabase project (Supabase Dashboard -> Authentication -> Add User)
#    - Promote the user to Owner by running the seed-owner script:
#      npm run db:seed-owner -- you@example.com
#    - For production environments, supply production env variables before the command:
#      DATABASE_URL="..." SUPABASE_SECRET_KEY="..." NEXT_PUBLIC_SUPABASE_URL="..." npm run db:seed-owner -- you@example.com

